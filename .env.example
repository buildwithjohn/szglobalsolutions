# Contact form (Resend) — copy to .env.local and fill in.
# Get an API key at https://resend.com/api-keys

# Required: your Resend API key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Where enquiries are delivered (defaults to support@szglobalsolutions.com)
CONTACT_TO_EMAIL=support@szglobalsolutions.com

# The "from" address. Must be on a domain you have VERIFIED in Resend.
# For quick testing you can use Resend's shared sender: onboarding@resend.dev
CONTACT_FROM_EMAIL=SZ Global Solutions <noreply@szglobalsolutions.com>
